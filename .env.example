# Supabase Postgres connection string (session pooler). Never commit the real value.
DATABASE_URL=

# Firebase Admin credential for verifying ID tokens. Provide ONE of:
#  - FIREBASE_SERVICE_ACCOUNT_JSON: the service-account JSON as a string (used on Render)
#  - GOOGLE_APPLICATION_CREDENTIALS: path to the service-account JSON file (used locally)
# Never commit the real value.
FIREBASE_SERVICE_ACCOUNT_JSON=
GOOGLE_APPLICATION_CREDENTIALS=
